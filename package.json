{
  "name": "webtrees-theme-rural",
  "version": "2.2.0",
  "description": "Rural theme for webtrees",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jon48/webtrees-theme-rural.git"
  },
  "author": "Jonathan Jaubart",
  "license": "GPL-3.0-or-later",
  "homepage": "https://github.com/jon48/webtrees-theme-rural#readme",
  "scripts": {
    "webtrees": "vite build --config=vite.config.webtrees.js",
    "rural": "vite build --config=vite.config.rural.js",
    "watch": "vite build --watch --config=vite.config.rural.js",
    "development": "npm run webtrees && npm run rural -- --mode development",
    "production": "npm run webtrees && npm run rural",
    "eslint": "semistandard --verbose | snazzy",
    "eslint-fix": "semistandard --verbose --fix | snazzy",
    "stylelint": "stylelint \"src/**/*.scss\" --rd",
    "stylelint-fix": "stylelint \"src/**/*.scss\" --rd --fix"
  },
  "dependencies": {
    "bootstrap": "5.3.8"
  },
  "devDependencies": {
    "autoprefixer": "^10.5.0",
    "browserslist-to-esbuild": "^2.1.1",
    "postcss-image-inliner": "^7.0.0",
    "postcss-rtlcss": "^6.0.0",
    "sass": "^1.34.0",
    "stylelint": "^17.4.0",
    "stylelint-config-sass-guidelines": "^13.0.0",
    "stylelint-config-standard": "^40.0.0",
    "vite": "^7.3.5",
    "vite-plugin-static-copy": "^4.1.1"
  },
  "browserslist": [
    ">0.1% and not dead"
  ]
}
